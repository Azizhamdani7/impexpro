# MongoDB Atlas
# Required for blogs, contact submissions, and admin reply threads.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=impexpro

# Admin authentication
# Use a long random value in production.
AUTH_SECRET=replace-with-a-long-random-secret

# Admin password hash
# Do NOT put the plain password here.
# Generate a bcrypt hash with:
# npm run hash-password -- "your-password"
# Then paste the generated ADMIN_PASSWORD_HASH value below.
ADMIN_PASSWORD_HASH=

# Gmail SMTP contact form and admin replies
# SMTP_PASS must be a Gmail App Password, not your normal Gmail password.
# Spaces in Gmail App Passwords are accepted by the app.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
CONTACT_RECEIVER_EMAIL=receiver@example.com
