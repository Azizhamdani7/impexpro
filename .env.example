# Local-only secret used to sign admin session cookies.
# Replace this with a unique long random secret in production.
AUTH_SECRET=local-development-auth-secret-change-in-production

# Admin password hash
# Do NOT put the plain password here.
# This value must be a bcrypt hash.
# Generate a bcrypt hash using:
# npm run hash-password -- "your-password"
# Then paste the generated ADMIN_PASSWORD_HASH value below.
# In .env files, bcrypt $ characters must be escaped as \$.
ADMIN_PASSWORD_HASH=\$2b\$12\$eaxmIhYnwnZDkFsZJJIO4.5aqsIv9aV4O7l4I5Je6g/ITFUPnYLRK

# Optional Gmail SMTP settings for contact form email delivery.
# Uncomment and set these to send email notifications.
# The contact form still saves submissions locally when SMTP is not configured.
# Use a Gmail App Password, not the normal Gmail account password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASS=your-gmail-app-password
# CONTACT_RECEIVER_EMAIL=receiver@example.com
